# Songloft 配置示例

# 管理员账号密码配置（必需）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# 服务配置
LISTEN_PORT=58091

# 数据库配置
DB_PATH=data/songloft.db

# 使用方式：
# 方式1: 环境变量配置
#   export ADMIN_USERNAME=admin
#   export ADMIN_PASSWORD=your_secure_password_here
#   export LISTEN_PORT=58091
#   export DB_PATH=data/songloft.db
#   ./songloft

# 方式2: 命令行参数
#   ./songloft -username admin -password your_secure_password_here -port 58091 -db data/songloft.db

# 方式3: 混合使用（命令行参数优先级更高）
#   export ADMIN_USERNAME=admin
#   export ADMIN_PASSWORD=your_secure_password_here
#   ./songloft -port 8080

# 注意事项：
# 1. 其他配置（如音乐目录、扫描配置、FFProbe 路径等）存储在数据库 config 表中
# 2. 可以通过 API 或直接修改数据库来更新这些配置
# 3. 优先级：命令行参数 > 环境变量 > 默认值
# 4. 首次启动会自动生成JWT密钥并存储在数据库中
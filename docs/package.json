{
  "devDependencies": {
    "playwright": "^1.61.1",
    "vitepress": "^1.5.0"
  },
  "scripts": {
    "sync": "node ../scripts/sync-docs.mjs",
    "fetch-issues": "node ../scripts/fetch-issues.mjs",
    "swagger-to-md": "node ../scripts/swagger-to-md.mjs",
    "docs:dev": "npm run sync && npm run fetch-issues && npm run swagger-to-md && vitepress dev --host=0.0.0.0 --port=3030",
    "docs:build": "npm run sync && npm run fetch-issues && npm run swagger-to-md && vitepress build",
    "docs:preview": "vitepress preview",
    "screenshots": "node scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "vite-plugin-vitepress-auto-sidebar": "^1.7.0",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}

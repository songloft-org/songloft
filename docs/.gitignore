# 构建产物
dist/
.vitepress/cache/
node_modules/
bun.lock

# 自动生成的 issues markdown（由 vitepress-plugin-github-issues 生成）
issues/

# 同步脚本从仓库根生成，不入库（见 scripts/sync-docs.mjs）
quick-start.md
changelog.md
NOTICE.md
PRIVACY.md
# 英文侧同样由 sync 生成（源为 *.en 文件）
en/quick-start.md
en/NOTICE.md
en/PRIVACY.md
# 子项目文档由 sync 生成
player/
tracely/
addon/
plugin-toolchain/

# 由 swagger-to-md.mjs 从 swagger.json 自动生成
swagger-api/
